# Gigaxity Deep Research — example environment (local-inference branch)
#
# Copy this file to .env and fill in the values you need.
# Anything left blank falls back to the default in src/config.py.
#
# All variables are prefixed with RESEARCH_ so they don't collide with
# unrelated tooling in the same shell environment.

# -- LLM (default: a local OpenAI-compatible server on port 8000) ------------
# Defaults work out of the box if you run vLLM or SGLang on localhost:8000.
# For Ollama, set RESEARCH_LLM_API_BASE=http://localhost:11434/v1.
# For remote services that enforce bearer auth (e.g. OpenRouter), set
# RESEARCH_LLM_API_BASE to that endpoint and put the real key in
# RESEARCH_LLM_API_KEY.
# RESEARCH_LLM_API_KEY must be non-empty — set any placeholder string for
# local servers that don't enforce auth.
RESEARCH_LLM_API_BASE=http://localhost:8000/v1
RESEARCH_LLM_API_KEY=local-anything
RESEARCH_LLM_MODEL=Alibaba-NLP/Tongyi-DeepResearch-30B-A3B
RESEARCH_LLM_TEMPERATURE=0.85
RESEARCH_LLM_TOP_P=0.95
RESEARCH_LLM_MAX_TOKENS=16384
RESEARCH_LLM_TIMEOUT=120

# -- SearXNG (primary search source) -----------------------------------------
# Run your own SearXNG instance (https://docs.searxng.org/) or point at any
# self-hosted or third-party SearXNG endpoint that exposes the JSON API.
RESEARCH_SEARXNG_HOST=http://localhost:8888
RESEARCH_SEARXNG_ENGINES=brave,bing,duckduckgo,startpage,mojeek,wikipedia
RESEARCH_SEARXNG_CATEGORIES=general
RESEARCH_SEARXNG_LANGUAGE=en
RESEARCH_SEARXNG_SAFESEARCH=0

# -- Tavily (optional fallback search) ---------------------------------------
# Get an API key at https://tavily.com
RESEARCH_TAVILY_API_KEY=
RESEARCH_TAVILY_SEARCH_DEPTH=advanced

# -- LinkUp (optional fallback search) ---------------------------------------
# Get an API key at https://linkup.so
RESEARCH_LINKUP_API_KEY=
RESEARCH_LINKUP_DEPTH=standard

# -- Search aggregation ------------------------------------------------------
RESEARCH_DEFAULT_TOP_K=10
RESEARCH_RRF_K=60

# -- Server (REST API mode only — ignored when running as MCP stdio) ---------
RESEARCH_HOST=127.0.0.1
RESEARCH_PORT=8000
