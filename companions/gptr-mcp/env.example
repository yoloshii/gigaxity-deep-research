# gptr-mcp environment template — social-first research configuration
#
# Copy this file to the gptr-mcp-source directory as `.env` and fill in the
# two required keys. The rest of the variables are pre-tuned for the
# social-first research workflow used by the parent project's research-workflow
# skill.
#
# Required:
#   OPENAI_API_KEY — used by the social_openai retriever AND the underlying LLM
#   TAVILY_API_KEY — used by the fallback web retriever
#
# Get keys at:
#   https://platform.openai.com/api-keys
#   https://tavily.com (free tier available)

# -- API keys (required) ------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-placeholder
TAVILY_API_KEY=your-tavily-api-key-placeholder

# -- Retriever selection ------------------------------------------------------
# social_openai → searches reddit.com, x.com, youtube.com (community knowledge)
# tavily        → general web fallback when social-first returns nothing
RETRIEVER=social_openai,tavily

# -- Social retriever scope ---------------------------------------------------
# Domains the social_openai retriever queries against. Default reflects the
# parent project's research-workflow skill priority order:
#   Reddit > X/Twitter > YouTube > general web (via tavily fallback)
SOCIAL_OPENAI_DOMAINS=reddit.com,x.com,youtube.com
SOCIAL_OPENAI_MODEL=gpt-4o

# -- LLM tier configuration ---------------------------------------------------
# gpt-4o-mini for cheap fast operations, gpt-4o for synthesis and reasoning.
# Swap all to gpt-4o-mini for cheaper-but-lower-quality operation.
FAST_LLM=openai:gpt-4o-mini
SMART_LLM=openai:gpt-4o
STRATEGIC_LLM=openai:gpt-4o-mini
