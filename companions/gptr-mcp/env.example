# gptr-mcp environment template
#
# Copy this file to the gptr-mcp-source directory as `.env` and fill in the
# required keys.
#
# Out of the box this runs as a stock GPT Researcher MCP (RETRIEVER=tavily).
# The social-first retrievers (social_openai + twitterapi) are an opt-in add-on
# — enable them once via CUSTOM_RETRIEVERS.md, then switch the RETRIEVER line
# below to the social-first block.
#
# Required:
#   OPENAI_API_KEY — the underlying LLM (and the social_openai retriever, if enabled)
#   TAVILY_API_KEY — the default web retriever
#
# Get keys at:
#   https://platform.openai.com/api-keys
#   https://tavily.com (free tier available)

# -- API keys (required) ------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-placeholder
TAVILY_API_KEY=your-tavily-api-key-placeholder

# -- Retriever selection ------------------------------------------------------
# Default: vanilla web retriever. Works immediately after ./install.sh.
RETRIEVER=tavily

# -- LLM tier configuration ---------------------------------------------------
# gpt-4o-mini for cheap fast operations, gpt-4o for synthesis and reasoning.
# Swap all to gpt-4o-mini for cheaper-but-lower-quality operation.
FAST_LLM=openai:gpt-4o-mini
SMART_LLM=openai:gpt-4o
STRATEGIC_LLM=openai:gpt-4o-mini

# =============================================================================
# SOCIAL-FIRST RETRIEVERS (opt-in) — requires a one-time enablement step.
#
# These retrievers do NOT exist in a vanilla GPT Researcher install. Enable them
# once per CUSTOM_RETRIEVERS.md, then comment out `RETRIEVER=tavily` above and
# uncomment the block below.
#
#   social_openai → Reddit (off-IP via Arctic Shift) + YouTube, via OpenAI web-search
#   twitterapi    → native X/Twitter search via TwitterAPI.io (paid key)
#
# WARNING: if you set RETRIEVER=social_openai,... WITHOUT enabling the retrievers,
# GPT Researcher silently falls back to Tavily for the unknown names — no error,
# no social results. Run the verify step in CUSTOM_RETRIEVERS.md first.
# -----------------------------------------------------------------------------
# RETRIEVER=social_openai,twitterapi,tavily
# SOCIAL_OPENAI_DOMAINS=reddit.com,youtube.com
# SOCIAL_OPENAI_MODEL=gpt-4o
# TWITTERAPI_IO_KEY=your-twitterapi-io-key-placeholder
#
# No paid X key? Use social_openai for X too (lower fidelity), drop twitterapi:
# RETRIEVER=social_openai,tavily
# SOCIAL_OPENAI_DOMAINS=reddit.com,x.com,youtube.com
