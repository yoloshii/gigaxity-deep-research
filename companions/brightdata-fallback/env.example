# brightdata-fallback environment template
#
# Copy this file to `.env` in this directory and fill in the two required
# values, OR pass them via the MCP `env` block in your `~/.claude.json`.
#
# The server fails fast at startup if either variable is missing — there is
# no default value, your account credentials are not bundled.
#
# Required:
#   BRIGHTDATA_API_TOKEN — your Brightdata API token
#   BRIGHTDATA_ZONE      — your Web Unlocker zone name
#
# Get an API token + Web Unlocker zone at: https://brightdata.com
# Pricing: https://brightdata.com/pricing/web-unlocker

BRIGHTDATA_API_TOKEN=your-brightdata-api-token-placeholder
BRIGHTDATA_ZONE=your-web-unlocker-zone-name
